# Unified .gitignore for monorepo (root)

# OS and editor files
.DS_Store
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
backend/logs/

# Node dependencies
node_modules/
.pnp
.pnp.js
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
coverage/

# Next.js build output (frontend)
frontend/.next/
frontend/out/

# Production build (backend)
backend/build/
backend/dist/

# Lock files
package-lock.json

# Env files
.env
# (keep .env.example files tracked)

# Vercel
frontend/.vercel/

# TypeScript
*.tsbuildinfo
frontend/next-env.d.ts
